{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["mocha", "chai", "node"]
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts", "target/types/**/*.ts"]
}
